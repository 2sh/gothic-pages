{
  "name": "gothic-pages",
  "version": "1.0.0",
  "main": "src/server/main.ts",
  "author": "2sh",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "rollup -c -w",
    "dev:server": "nodemon src/server/main.ts -e ts",
    "build": "yarn build:init && yarn build:js && yarn build:assets && yarn build:static && yarn build:html",
    "build:init": "rm -fr build",
    "build:js": "rollup -c",
    "build:assets": "cp -r src/client/assets/ build/",
    "build:static": "cp -r static/* build/",
    "build:html": "tsx src/server/main.ts build"
  },
  "dependencies": {
    "@bbob/html": "^4.2.0",
    "@bbob/preset-html5": "^4.2.0",
    "@root/walk": "^1.1.0",
    "alpinejs": "^3.14.9",
    "express": "^5.1.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@tsconfig/node20": "^20.1.2",
    "@types/alpinejs": "^3.13.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
    "glob": "^11.0.2",
    "nodemon": "^3.0.3",
    "rollup": "^4.46.2",
    "rollup-plugin-delete": "^3.0.1",
    "rollup-plugin-header": "^1.0.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
